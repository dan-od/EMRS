# ─── Postgres ──────────────────────────────────────────────────────────────────
DB_USER=emrs_admin
DB_PASSWORD=          # REQUIRED — generate: openssl rand -base64 24
DB_NAME=emrs_wellfluid
# DB_HOST and DB_PORT are set by docker-compose — do not add here

# ─── JWT secrets ───────────────────────────────────────────────────────────────
JWT_SECRET=           # REQUIRED — generate: openssl rand -hex 64
JWT_REFRESH_SECRET=   # REQUIRED — generate: openssl rand -hex 64
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://emrs.okoro.me       # REQUIRED — used for CORS origin
VITE_API_URL=https://emrs.okoro.me/api   # REQUIRED — baked into frontend build

# ─── Email / SMTP (optional — leave empty to disable) ──────────────────────────
# Password reset and email notifications will not work until these are set.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=EMRS <noreply@wellfluid.com>

# ─── SMS via Termii (optional — leave SMS_ENABLED=false to disable) ────────────
# In-app notifications still work; SMS delivery will not until these are set.
SMS_ENABLED=false
TERMII_API_KEY=
TERMII_SENDER_ID=WellFluid

# ─── Error tracking via Sentry (optional) ──────────────────────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
