# EMRS Backend Environment Configuration
# Copy this to .env and fill in your values

# =====================================================
# SERVER
# =====================================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emrs_db
DB_USER=postgres
DB_PASSWORD=your_database_password

# =====================================================
# JWT Authentication
# =====================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# =====================================================
# Error Tracking (Sentry)
# =====================================================
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# =====================================================
# EMAIL (SMTP) - Using Gmail as example
# =====================================================
# For Gmail: Enable "Less secure app access" or use App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@wellfluid.com

# For other providers:
# Outlook: smtp.office365.com, port 587
# SendGrid: smtp.sendgrid.net, port 587
# Mailgun: smtp.mailgun.org, port 587

# =====================================================
# SMS (Termii - Nigerian SMS Provider)
# =====================================================
# Get API key from https://termii.com
SMS_ENABLED=false
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=WellFluid

# Cost: Approximately ₦2.5 per SMS
# Note: Sender ID must be registered and approved by Termii

# =====================================================
# FILE UPLOADS
# =====================================================
# Max file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# =====================================================
# OPTIONAL: Redis (for session management, rate limiting)
# =====================================================
# REDIS_URL=redis://localhost:6379

# =====================================================
# OPTIONAL: Cloud Storage (for file uploads)
# =====================================================
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=emrs-uploads
# AWS_REGION=us-east-1

# =====================================================
# Phase 5: Accounts Configuration
# =====================================================
# High cost threshold for priority notifications (in Naira)
HIGH_COST_THRESHOLD=100000
