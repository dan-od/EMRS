# ════════════════════════════════════════════════════
#  EMRS .gitignore
# ════════════════════════════════════════════════════

# ─── Node / npm ────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/

# ─── Environment files (NEVER commit) ──────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
**/.env
**/.env.local
**/.env.*.local

# ─── Build outputs ──────────────────────────────────
dist/
build/
out/
.cache/
.next/
.vite/
*.tsbuildinfo

# ─── Code archives (zips of past states) ───────────
backup/
archives/
*.zip
*.tar.gz
*.tgz

# ─── DB backups stay LOCAL ONLY ────────────────────
# Homelab/GitHub deploy uses migrations + seed, not dumps.
backups/**/*.dump
backups/**/*.sql
backups/**/*.sql.gz

# Audit reports stay tracked (useful documentation)
!backups/**/*.md

.claude/
/package.json
/package-lock.json

# ─── IDE / editor ──────────────────────────────────
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ─── OS junk ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ──────────────────────────────────────────
*.log
logs/

# ─── Temporary files ───────────────────────────────
*.tmp
*.temp
.tmp/

# ─── Coverage / testing ────────────────────────────
coverage/
.nyc_output/

# ─── Generated / compiled ──────────────────────────
*.local